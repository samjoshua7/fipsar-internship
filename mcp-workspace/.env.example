# =============================================================
# FIPSAR Internship — API Data Ingestion Pipeline
# Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in every value marked with <...>
#   3. Never commit .env to Git — it is in .gitignore
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
# Inside Docker, POSTGRES_HOST must be "postgres" (the service name).
# For running scripts locally outside Docker, change to "localhost".
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=api_ingestion_mcp
POSTGRES_USER=<your_db_user>
POSTGRES_PASSWORD=<your_db_password>

# ── Airflow — Security Keys ───────────────────────────────────
# Generate FERNET_KEY (encrypts DB-stored secrets):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=<generate_and_paste_here>

# Generate SECRET_KEY (signs web session cookies):
#   python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=<generate_and_paste_here>

# ── Airflow — Admin User ──────────────────────────────────────
# Credentials for the Airflow UI login page (http://localhost:8080)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=<your_airflow_ui_password>
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ── API ───────────────────────────────────────────────────────
API_BASE_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT=30

# ── Logging ───────────────────────────────────────────────────
# LOG_LEVEL options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_DIR=./logs
