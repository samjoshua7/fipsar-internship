# Airflow UID (typically 50000 for Docker)
AIRFLOW_UID=50000

# Airflow Web UI Admin Credentials
# CHANGE THESE IN YOUR LOCAL .env FILE
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme_secure_password

# Fernet key for encrypting sensitive data
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MUST be set in .env for production
FERNET_KEY=your_generated_fernet_key_here

# JWT Configuration
AIRFLOW__API_AUTH__JWT_SECRET=your_jwt_secret_here
AIRFLOW__API_AUTH__JWT_ISSUER=airflow
